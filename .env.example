# GA4 web stream measurement ID, for example: G-XXXXXXXXXX
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# SMTP settings for valuation lead notifications.
# Put real values in Vercel environment variables or local .env.local.
SMTP_HOST=
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASS=
LEAD_NOTIFY_TO=
LEAD_NOTIFY_FROM=

# Agent CRM property enquiry webhook. The URL has a production default.
# Set the secret only when HOUEZ_WEBHOOK_SECRET is enabled in Agent CRM.
AGENT_CRM_WEBHOOK_URL=https://agent.move2marbella.com/api/webhooks/houzez
AGENT_CRM_WEBHOOK_SECRET=
